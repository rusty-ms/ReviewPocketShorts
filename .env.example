# ============================================================
# ReviewPocketShorts - Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to GitHub.
# ============================================================

# --- Amazon Product Advertising API ---
# Apply at: https://affiliate-program.amazon.com/assoc_registrations/apply
AMAZON_ACCESS_KEY=your_amazon_access_key
AMAZON_SECRET_KEY=your_amazon_secret_key
AMAZON_PARTNER_TAG=reviewpockets-20
AMAZON_HOST=webservices.amazon.com
AMAZON_REGION=us-east-1

# --- OpenAI ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# --- TTS (OpenAI TTS — uses your OPENAI_API_KEY above) ---
# Voice options: nova (warm female), shimmer (expressive female),
#                alloy (neutral), echo (male), fable (expressive male), onyx (deep male)
TTS_VOICE=nova

# --- YouTube Data API v3 ---
# https://console.cloud.google.com → YouTube Data API v3
# OAuth2 credentials (client_secret.json) - see README
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=youtube_token.json
YOUTUBE_CHANNEL_ID=your_youtube_channel_id

# --- Meta Graph API (Instagram) ---
# https://developers.facebook.com/apps/
# Requires: Business account + Facebook Page + Instagram Professional account
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_long_lived_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id

# --- App Settings ---
VIDEO_OUTPUT_DIR=./output
TEMP_DIR=./temp
DATA_DIR=./data
USED_PRODUCTS_FILE=./data/used_products.json

# --- Amazon Categories to pull from (comma-separated) ---
# Options: Electronics, Beauty, Kitchen, Toys, Sports, Books, Home, Garden
AMAZON_CATEGORIES=Electronics,Beauty,Kitchen,Toys,Sports

# --- Video Settings ---
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_DURATION_TARGET=45
